# NovaBridge one-click launcher environment template
# Copy to: novabridge.env

# Core project/runtime
NOVABRIDGE_PROJECT=./NovaBridgeDefault/NovaBridgeDefault.uproject
NOVABRIDGE_PORT=30010
NOVABRIDGE_OPEN_STUDIO=1
NOVABRIDGE_SKIP_ASSISTANT=0
NOVABRIDGE_ASSISTANT_PORT=30016

# Core plugin auth
NOVABRIDGE_API_KEY=
NOVABRIDGE_DEFAULT_ROLE=automation

# Assistant provider selection:
# mock | openai | anthropic | ollama | custom
NOVABRIDGE_ASSISTANT_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
NOVABRIDGE_ASSISTANT_OPENAI_MODEL=gpt-4.1

# Anthropic
ANTHROPIC_API_KEY=
NOVABRIDGE_ASSISTANT_ANTHROPIC_MODEL=claude-sonnet-4-5

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
NOVABRIDGE_ASSISTANT_OLLAMA_MODEL=llama3.1:8b

# Custom provider endpoint
NOVABRIDGE_ASSISTANT_CUSTOM_URL=
NOVABRIDGE_ASSISTANT_CUSTOM_HEADER_KEY=
NOVABRIDGE_ASSISTANT_CUSTOM_HEADER_VALUE=

# OpenClaw bridge
NOVABRIDGE_HOST=127.0.0.1
NOVABRIDGE_VOICE_HOST=127.0.0.1
