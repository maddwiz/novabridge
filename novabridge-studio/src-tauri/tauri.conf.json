{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovaBridge Studio",
  "version": "1.0.2",
  "identifier": "com.novabridge.studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NovaBridge Studio",
        "width": 1480,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
